# Never commit API keys or secrets
.env
.env.local
*.env
secrets.md
api-keys.md

# Obsidian workspace files (local only)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian plugin data (may contain API keys)
.obsidian/plugins/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code worktrees (isolated branch workspaces)
.claude/worktrees/

# Attachments that are too large for git
_attachments/*.mp4
_attachments/*.mov
_attachments/*.zip

# Temp files
*.tmp
*.bak
